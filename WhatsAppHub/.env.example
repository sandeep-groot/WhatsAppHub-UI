/**
 * .env.example - Copy this file to .env.local and fill in the values
 */

# API Configuration (backend base URL including version prefix)
NEXT_PUBLIC_API_URL=http://localhost:5000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WhatsAppHub

# Optional: Authentication
# NEXT_AUTH_URL=http://localhost:3000
# NEXT_AUTH_SECRET=your-secret-key-here

# Optional: Feature flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
